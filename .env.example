# J-Link RTT MCP Server Configuration
# Copy this file to .env and adjust as needed.
# These are all OPTIONAL — the tool works with sensible defaults.

# Optional: J-Link serial number (leave empty to use first available)
JLINK_SERIAL=

# Target device name. Defaults to "Cortex-M0+".
# Override per project, e.g. for HDSC: JLINK_DEVICE=HC32L19x, or STM32F103, etc.
# The `device` arg passed to the `jlink_connect` tool always wins over this.
# JLINK_DEVICE=HC32L19x

# JTAG/SWD speed in kHz
JLINK_SPEED=4000

# Default RTT channel
RTT_CHANNEL=0

# Ring buffer size (number of entries to keep)
RTT_RING_BUFFER_SIZE=100

# Poll interval in milliseconds (how often to check RTT)
RTT_POLL_INTERVAL_MS=10

# RTT output log file. Leave unset for a portable per-user default:
#   Windows: %LOCALAPPDATA%\mcp-rtt-server\rtt_output.log
#   Linux:   ~/.local/state/mcp-rtt-server/rtt_output.log
# Set this to override (e.g. to a project-local path).
# RTT_LOG_FILE=./rtt_output.log

# Mock mode: set to 1 to use the in-process software backend (no J-Link or
# hardware required). The daemon/serve process emits a synthetic heartbeat
# line on each RTT read so the triple-sink (log + stderr + ring) can be
# exercised end-to-end. Useful for development and CI.
# RTT_MOCK=1

# SEGGER library override: when auto-detection misses (DLL/dylib in a
# non-standard location), set this to the full path of JLink_x64.dll /
# libjlinkarm.so / libjlinkarm.dylib. RTT_LIB_PATH is an alias.
# JLINK_LIB_PATH=C:\Program Files\SEGGER\JLink_V950\JLink_x64.dll

# Auth (optional): when set, /sse, /messages/ and /shutdown require
# Authorization: Bearer <RTT_AUTH_TOKEN>. Useful for multi-tenant / CI
# environments; leave unset for single-user dev boxes.
# RTT_AUTH_TOKEN=some-long-random-string
