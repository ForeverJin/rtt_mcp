# J-Link RTT MCP Server Configuration
# Copy this file to .env and adjust as needed

# Optional: J-Link serial number (leave empty to use first available)
JLINK_SERIAL=

# Target device name (see pylink documentation for supported devices)
JLINK_DEVICE=HC32L19x

# JTAG/SWD speed in kHz
JLINK_SPEED=4000

# Default RTT channel
RTT_CHANNEL=0

# Ring buffer size (number of entries to keep)
RTT_RING_BUFFER_SIZE=100

# Poll interval in milliseconds (how often to check RTT)
RTT_POLL_INTERVAL_MS=10
